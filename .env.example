# Copy to .env (gitignored) and uncomment what you need.
#
# docker-compose auto-loads .env at `up` time, so any value set here will
# override the compose file's defaults. That matters for service URLs —
# `localhost` inside a container means the container itself, not the host.
# See each group below.

# ── Indexer GraphQL ───────────────────────────────────────────────────────
# Docker:   leave unset — compose defaults to http://host.docker.internal:3000
# pnpm dev: uncomment so the API on the host talks to the indexer on the host
# INDEXER_GRAPHQL_URL=http://localhost:3000

# ── Redis (optional, for API response caching) ───────────────────────────
# Docker:   leave unset — compose defaults to redis://redis:6379 (service name)
# pnpm dev: uncomment to use your local Redis instance
# REDIS_URL=redis://localhost:6379

# ── API server ────────────────────────────────────────────────────────────
# Safe to override in both environments.
# API_PORT=8080
# API_HOST=0.0.0.0

# ── Chain RPC (for supply, TVL, APR, providers, specs) ───────────────────
# LAVA_REST_URL=https://lava.rest.lava.build
# LAVA_RPC_URL=https://lava.tendermintrpc.lava.build:443
# RPC_BATCH_SIZE=25

# ── Frontend ──────────────────────────────────────────────────────────────
# Used at Next.js build time. The browser hits the API directly, so this
# is always the user-facing URL, not an internal docker hostname.
# NEXT_PUBLIC_API_URL=http://localhost:8080

# ── CoinGecko / Keybase ──────────────────────────────────────────────────
# COINGECKO_API_URL=https://api.coingecko.com/api/v3
# KEYBASE_API_URL=https://keybase.io/_/api/1.0

# ── Relays DB (optional — consumer optimizer metrics) ────────────────────
# RELAYS_DB_URL=postgresql://user:password@host:5432/relays

# ── Health probe (runs in-process on the API when enabled) ───────────────
# ENABLE_HEALTH_PROBE=true
# HEALTH_PROBE_REGION=US
# HEALTH_PROBE_INTERVAL_MS=30000

# ── Precompute worker (runs as its own bin/precompute.ts) ────────────────
# PRECOMPUTE_INTERVAL_MS=900000
